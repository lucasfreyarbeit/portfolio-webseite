---
import Button from "../navigation/Button.astro";
import ImageBox from "../ui/ImageBox.astro";
import Logo from "../ui/Logo.astro";
---

<section id="hero">
    <div class="row">
        <!-- Linke Spalte: Fokus auf Portrait -->
        <div class="column-left border-left-solid border-right-dashed">
            <div class="portrait-wrapper">
                <ImageBox src="/images/portraits/Downscaled.jpg" alt="Portrait von Lucas" />
            </div>
        </div>

        <!-- Rechte Spalte: Branding, Biografie und Skills -->
        <div class="column-right border-right-solid">
            <div class="logo-wrapper">
                <Logo variant="black" />
            </div>
            
            <h2 class="subheading">
                <span class="text-designer">DESIGNER.</span> 
                <span class="text-developer">DEVELOPER.</span>
            </h2>
            
            <div class="bio-content">
                <h3>ÜBER MICH</h3>
               <p>
                    Ich verbinde Development, Design und Business. Als technischer Generalist löse ich Probleme 
                    auf jeder Ebene eines Projekts: Ich entwickle das Produkt, gestalte das gesamte Branding samt Design 
                    und kümmere mich um das Publishing sowie das strategische Skalieren.
</p>
            </div>

            <!-- Toolstack-Sektion zur optimalen Raumausnutzung -->
            <div class="tech-stack">
                <h3>TOOLSTACK</h3>
                <div class="stack-grid">
                    <span class="tech-tag">Astro</span>
                    <span class="tech-tag">HTML / CSS</span>
                    <span class="tech-tag">VS Code</span>
                    <span class="tech-tag">Git / GitHub</span>
                    <span class="tech-tag">Godot Engine</span>
                    <span class="tech-tag">Unity</span>
                </div>
            </div>
            
            <!-- Primäre CTAs als Abschluss des Leseflusses -->
            <div class="action-area">
                <Button href="#projekte" variant="red">PROJEKTE</Button>
                <Button href="#kontakt" variant="blue">KONTAKT</Button>
                <Button href="/documents/Lebenslauf-Lucas-Frey.pdf" download variant="red">LEBENSLAUF.PDF</Button>
            </div>
        </div>
    </div>
</section>

<style>
    * {
        box-sizing: border-box;
    }

    #hero {
        width: 100%;
        padding-top: 1rem;
    }

    .row {
        display: flex;
        flex-direction: row;
        width: 100%; 
        margin: 0 auto; 
        padding: 0rem 1rem;
    }

    .column-left,
    .column-right {
        border-top: 3px solid var(--border-color);
        border-bottom: 3px solid var(--border-color);
        padding: 2rem;
    }

    /* 1/3 zu 2/3 Asymmetrie */
    .column-left {
        flex: 0.5; 
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
    }

    .column-right {
        flex: 1; 
        display: flex;
        flex-direction: column;
    }

    .portrait-wrapper {
        width: 100%;
        height: auto;
    }

    /* Rahmenlinien */
    .border-left-solid {
        border-left: 3px solid var(--border-color);
    }

    .border-right-solid {
        border-right: 3px solid var(--border-color);
    }

    .border-right-dashed {
        border-right: 2px dashed var(--border-color);
    }

    /* Branding */
    .logo-wrapper {
        transform: scale(3);
        transform-origin: left center;
        margin-top: 1.2rem;
        margin-bottom: 2rem;
        margin-left: -0.4rem;
    }

    .subheading {
        margin-top: 0;
        margin-bottom: 2rem;
        font-weight: 700;
        font-size: 160%;
        border-bottom: 2px dashed var(--border-color);
        padding-bottom: 0.5rem;
    }

    .text-designer {
        color: var(--accent-2);
        margin-right: 1rem;
    }

    .text-developer {
        color: var(--accent-1);
    }

    /* Content-Strukturen */
    .bio-content h3,
    .tech-stack h3 {
        font-family: var(--font-heading, monospace);
        font-size: 1.1rem;
        font-weight: 700;
        margin-top: 0;
        margin-bottom: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .bio-content p {
        margin-top: 0;
        margin-bottom: 2rem;
        line-height: 1.6;
        font-size: var(--step-body, 1.1rem);
    }

    /* Tech Stack Grid Integration */
    .tech-stack {
        margin-bottom: 2.5rem;
    }

    .stack-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .tech-tag {
        font-family: var(--font-heading, monospace);
        font-size: 0.85rem;
        font-weight: 600;
        padding: 0.4rem 0.8rem;
        background-color: transparent;
        border: 2px solid var(--border-color);
        color: var(--text-color);
        text-transform: uppercase;
    }

    /* Call to Action Platzierung */
    .action-area {
        margin-top: auto; 
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-start; 
        gap: 1rem; 
        padding-top: 1.5rem; 
        width: 100%;
        border-top: 2px dashed var(--border-color);
    }

    /* Responsive Layout-Kippung */
    @media (max-width: 992px) {
        .action-area {
            flex-direction: column;
        }
    }

    @media (max-width: 768px) {
        #hero {
            padding-top: 2rem;
        }

        .row {
            flex-direction: column;
        }

        .column-left {
            border-right: 3px solid var(--border-color);
            border-bottom: none;
            padding-bottom: 1rem;
        }

        .column-right {
            border-top: 2px dashed var(--border-color);
        }

        .logo-wrapper {
            transform: scale(2);
        }

        .action-area {
            flex-direction: row;
        }
    }

    @media (max-width: 480px) {
        .action-area {
            flex-direction: column;
        }
    }
</style>