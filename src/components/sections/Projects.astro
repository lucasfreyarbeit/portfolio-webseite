---
import Button from "../navigation/Button.astro";
import ImageBox from "../ui/ImageBox.astro";
import FadeIn from "../animations/FadeIn.svelte";
---

<section id="projekte">

    <!-- Sektions-Header -->
    <div class="row">
        <div class="col-full border-top-solid border-left-solid border-right-solid bg-subtle">
            <FadeIn client:visible delay={0}>
                <h1 class="section-title">PROJEKTE</h1>
            </FadeIn>
        </div>
    </div>

    <!-- Projektkarte 01 (Neues Projekt: Godot Android-App) -->
    <div class="row">

        <div class="col-image border-left-solid border-right-dashed">
            <FadeIn client:visible delay={0}>
                <ImageBox
                    src="/images/projects/Placeholder.png"
                    alt="Android App Projekt Vorschau"
                />
            </FadeIn>
        </div>

        <div class="col-text border-right-solid">

            <FadeIn client:visible delay={100}>
                <h1 class="project-title">ANDROID APP (BALD)</h1>
            </FadeIn>

            <FadeIn client:visible delay={200}>
                <h2 class="sub-heading">BESCHREIBUNG</h2>
            </FadeIn>

            <FadeIn client:visible delay={300}>
                <p>
                    Entwicklung einer interaktiven Android-App mit Fokus auf performantes UI-Design, flüssige Animationen und native Steuerungselemente.<br />
                    Fokus auf saubere Architektur und ressourcenschonende Umsetzung für mobile Endgeräte.
                </p>
            </FadeIn>

            <FadeIn client:visible delay={350}>
                <div class="tech-stack">
                    <h2 class="sub-heading">VERWENDETE TECHNOLOGIEN</h2>
                    <div class="tags">
                        <span class="tag">GODOT</span>
                        <span class="tag">GDSCRIPT</span>
                        <span class="tag">BLENDER</span>
                    </div>
                </div>
            </FadeIn>

            <div class="button-wrapper">
                <div class="buttons">
                    <FadeIn client:visible delay={400}>
                        <Button
                            href="/projekte/android-app"
                            variant="red"
                        >
                            PROJEKT GENAUER ANSEHEN
                        </Button>
                    </FadeIn>

                    <FadeIn client:visible delay={500}>
                        <Button
                            href="#"
                            variant="blue"
                        >
                            LIVE DEMO
                        </Button>
                    </FadeIn>
                </div>
            </div>

        </div>

    </div>

    <!-- Projektkarte 02 (Diese Website) -->
    <div class="row">

        <div class="col-text border-left-solid border-right-dashed">

            <FadeIn client:visible delay={0}>
                <h1 class="project-title">PORTFOLIO WEBSITE</h1>
            </FadeIn>

            <FadeIn client:visible delay={100}>
                <h2 class="sub-heading">BESCHREIBUNG</h2>
            </FadeIn>

            <FadeIn client:visible delay={200}>
                <p>
                    Meine allererste eigene Website, gebaut von Grund auf mit modernen Web-Technologien.<br />
                    Fokus auf minimalistisches Design, saubere Rasterstrukturen, modulare Komponenten und schnelle Ladezeiten.
                </p>
            </FadeIn>

            <FadeIn client:visible delay={250}>
                <div class="tech-stack">
                    <h2 class="sub-heading">VERWENDETE TECHNOLOGIEN</h2>
                    <div class="tags">
                        <span class="tag">ASTRO</span>
                        <span class="tag">SVELTE</span>
                        <span class="tag">CSS</span>
                    </div>
                </div>
            </FadeIn>

            <div class="button-wrapper">
                <div class="buttons">
                    <FadeIn client:visible delay={300}>
                        <Button
                            href="/projekte/portfolio-website"
                            variant="red"
                        >
                            PROJEKT GENAUER ANSEHEN
                        </Button>
                    </FadeIn>

                    <FadeIn client:visible delay={400}>
                        <Button 
                            href="https://lucasfrey.de/" 
                            variant="blue"
                        >
                            LIVE DEMO
                        </Button>
                    </FadeIn>
                </div>
            </div>

        </div>

        <div class="col-image border-right-solid">
            <FadeIn client:visible delay={400}>
                <ImageBox
                    src="/images/projects/Placeholder.png"
                    alt="Portfolio Website Projekt Vorschau"
                />
            </FadeIn>
        </div>

    </div>

</section>

<style>
    * {
        box-sizing: border-box;
    }

    /* Grid-Struktur */
    .row {
        display: flex;
        align-items: stretch;
        width: 100%;
        margin: 0 auto;
        padding: 0 1rem;
    }

    /* Spalten-Layouts */
    .col-full,
    .col-image,
    .col-text {
        padding: 1.5rem;
        border-bottom: 3px solid var(--border-color);
    }

    .col-full {
        flex: 1;
    }

    .col-image {
        flex: 0.5;
    }

    .col-text {
        display: flex;
        flex: 1;
        min-width: 0;
        flex-direction: column;
    }

    .col-text p {
        font-style: italic;
        margin-bottom: 1rem;
    }

    /* Utility Borders */
    .border-top-solid {
        border-top: 3px solid var(--border-color);  
    }   
        
    .border-left-solid {
        border-left: 3px solid var(--border-color);
    }

    .border-right-solid {
        border-right: 3px solid var(--border-color);
    }

    .border-right-dashed {
        border-right: 2px dashed var(--border-color);
    }

    /* Subtiler Hintergrund für Sektions-Header */
    .bg-subtle {
        background-color: #292929;
    }

    /* Gemeinsame Typografie-Basis für Haupt- und Projektüberschriften */
    .section-title,
    .project-title {
        margin: 0 0 0.5rem 0;
        font-size: var(--step-hero-title);
        font-weight: 700;
        line-height: 1;
        letter-spacing: -0.02em;
    }

    /* Sektions-Header Überschrift */
    .section-title {
        color: #ffffff;
    }

    /* Titel der einzelnen Projektkarten */
    .project-title {
        color: var(--text-color);
    }

    .sub-heading {
        margin-top: 1rem;
        margin-bottom: 0.25rem;
        font-size: var(--step-subheading);
        font-family: var(--font-heading);
        letter-spacing: 0.05em;
    }

    /* Tech-Stack Badges */
    .tech-stack {
        margin-top: auto;
        margin-bottom: 1.5rem;
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }

    .tag {
        padding: 0.4rem 0.8rem;
        border: 2px solid var(--border-color);
        background-color: transparent;
        font-size: var(--step-small);
        font-weight: 700;
        text-transform: uppercase;
    }

    /* Button-Container & Ausrichtung am unteren Rand */
    .button-wrapper {
        width: 100%;
        margin-top: auto;
    }

    .buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: flex-start;
        width: 100%;
        padding-top: 1.5rem;
        border-top: 2px dashed var(--border-color);
    }

    /* Mobile Adaption */
    @media (max-width: 768px) {
        .row {
            flex-direction: column;
        }

        .col-image,
        .col-text {
            width: 100%;
            flex: 1 1 auto;
        }

        .row:nth-child(even) {
            flex-direction: column-reverse;
        }
    }
</style>