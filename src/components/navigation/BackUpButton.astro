---
import BackIcon from '../../assets/icons/chevron.svg';

interface Props {
    href: string;
}

const { href } = Astro.props;
---

<div id="backup-button-container" class="backup-sticky-wrapper" data-visible="false">
    <a href={href} class="button">
        <BackIcon class="button-icon" aria-hidden="true" />
        <span>ZURÜCK NACH OBEN</span>
    </a>
</div>

<style>
    /* Der Wrapper regelt das Festkleben am Footer-Rand */
    .backup-sticky-wrapper {
        position: sticky;
        bottom: 2rem;
        z-index: 99;
        display: flex;
        justify-content: center;
        width: 100%;
        pointer-events: none;
        margin-top: 1rem;
        margin-bottom: 1rem;

        /* Übergang für das Ein- und Ausblenden (Hero-Logik) */
        opacity: 0;
        transform: translateY(20px);
        transition: transform .25s ease, opacity .25s ease;
    }

    /* Wird vom JS gesteuert, sobald der Hero verlassen wird */
    .backup-sticky-wrapper[data-visible="true"] {
        opacity: 1;
        transform: translateY(0);
    }

    .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: .2rem 1rem;
        gap: 0.5rem; 
        text-decoration: none;
        font-family: var(--font-heading);
        font-weight: 700;
        font-size: 1rem;
        background-color: var(--accent-2);
        color: var(--bg-color);
        border: 2px solid var(--outline-color);
        filter: drop-shadow(3px 3px 0 var(--shadow-color));
        pointer-events: auto; /* Aktiviert Klicks nur auf dem Button selbst */
        
        transition:
            transform .08s,
            filter .08s,
            background-color .15s,
            color .15s;
    }

    .button-icon {
        width: 1rem;
        height: 1rem;
        fill: currentColor;
        stroke: currentColor;
    }

    .button:hover {
        transform: translate(-1.5px, -1.5px);
        filter: drop-shadow(4.5px 4.5px 0 var(--shadow-color));
        background-color: var(--accent-1);
        color: var(--bg-color); 
    }

    .button:active {
        transform: translate(1.5px, 1.5px);
        filter: none;
    }
</style>

<script>
    function initHeroObserver() {
        const hero = document.querySelector('#hero');
        const container = document.querySelector('#backup-button-container');

        if (!container) return;

        if (hero) {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    // Wenn der Hero NICHT mehr zu sehen ist, zeige den Button
                    container.setAttribute('data-visible', (!entry.isIntersecting).toString());
                });
            }, { threshold: 0 });

            observer.observe(hero);
        } else {
            // Fallback: Falls auf einer Unterseite kein Hero existiert, Button direkt zeigen
            container.setAttribute('data-visible', 'true');
        }
    }

    // Start bei Initialisierung und View Transitions / Swaps
    initHeroObserver();
    document.addEventListener('astro:after-swap', initHeroObserver);
</script>