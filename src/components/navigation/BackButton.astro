---
import BackIcon from '../../../public/icons/ui/BackIcon.svg';

interface Props {
    href: string;
}

const { href } = Astro.props;
---

<a href={href} class="button">
    <BackIcon class="button-icon" aria-hidden="true" />
    <span>ZURÜCK</span>
</a>

<style>
.button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    padding: .3rem .5rem;
    
    /* 3. Add a gap between the SVG and the text */
    gap: 0.2rem; 

    text-decoration: none;
    color: inherit;

    font-family: "JetBrains Mono", monospace;
    font-weight: 600;
    font-size: .8rem;

    background: white;
    border: 2px solid #2d2d2d;
    filter: drop-shadow(3px 3px 0 #282828);

    transition:
        transform .08s,
        filter .08s,
        background-color .15s,
        color .15s;
}

/* 4. Style the icon size and ensure it responds to the hover color */
.button-icon {
    width: 1.2rem;
    height: 1.2rem;
    fill: currentColor;   /* Forces the SVG to use the button's text color */
    stroke: currentColor; /* Forces the SVG stroke to use the text color */
}

.button:hover {
    transform: translate(-1.5px, -1.5px);
    filter: drop-shadow(4.5px 4.5px 0 #282828);
    background: #4a4a4a;
    color: white; /* The SVG will automatically turn white here */
}

.button:active {
    transform: translate(1.5px, 1.5px);
    filter: none;
}
</style>
