---
interface Props {
    class?: string;
    variant?: "default" | "footer";
}

const { class: className = "", variant = "default" } = Astro.props;
---

<div class={`divider divider--${variant} ${className}`} />

<style>
    * {
        box-sizing: border-box;
    }

    /* Basiskonfiguration */
    .divider {
        display: block;
        width: 100%; /* Füllt die komplette Breite des übergeordneten Elements */
        height: 2px;
    }

    /* Varianten */
    .divider--default {
        background-color: var(--divider-color);
        margin: 3rem 0; /* Horizontales Zentrieren über margin-auto entfernt */
    }

    .divider--footer {
        background-color: var(--divider-footer-color);
        margin: 1rem 0 0rem 0;
    }
</style>