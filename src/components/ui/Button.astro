---
interface Props {
    href: string;
    variant?: "default" | "red" | "orange" | "blue";
    theme?: "light" | "dark"; // "light" = dunkler Rahmen (Standard), "dark" = heller Rahmen für dunkle Backgrounds
}

const {
    href,
    variant = "default",
    theme = "light",
}: Props = Astro.props;
---

<a
    href={href}
    class={`button button--${variant} button--theme-${theme}`}
>
    <slot />
</a>

<style>
/* --- 1. GEMEINSAME BASIS-STYLES --- */
.button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: .20rem .70rem;

    font-family: "Roboto Mono", monospace;
    font-size: .95rem;
    text-decoration: none;
    border: 2px solid; /* Breite steht fest, Farbe kommt über das Theme */

    transition:
        background-color .15s ease,
        color .15s ease,
        border-color .15s ease,
        transform .08s ease,
        filter .08s ease;
}

/* Hover- & Klick-Animationen (gelten für beide Themes) */
.button:hover {
    transform: translate(-1.5px, -1.5px);
    cursor: pointer;
}

.button:active {
    transform: translate(1.5px, 1.5px);
    filter: none !important; /* Entfernt den Schatten beim Klicken */
}


/* --- 2. THEME "LIGHT" (Für helle Seiten-Hintergründe) --- */
.button--theme-light {
    background: #ffffff;
    color: #282828;
    border-color: #282828;
    filter: drop-shadow(3px 3px 0 #282828);
}

.button--theme-light:hover {
    filter: drop-shadow(5px 5px 0 #282828);
}

.button--theme-light:focus-visible {
    outline: 2px solid #282828;
    outline-offset: 4px;
}


/* --- 3. THEME "DARK" (Für dunkle Hintergründe wie deinen Footer) --- */
.button--theme-dark {
    background: #ffffff;
    color: #282828;
    border-color: #ffffff; /* Heller Rahmen, damit man ihn sieht */
    filter: drop-shadow(3px 3px 0 #000000); /* Knallharter, pechschwarzer Schatten */
}

.button--theme-dark:hover {
    filter: drop-shadow(5px 5px 0 #000000); /* Tieferer pechschwarzer Schatten */
}

.button--theme-dark:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 4px;
}


/* --- 4. FARB-VARIANTE-HOVER (Unabhängig vom Theme) --- */
.button--default:hover {
    background: #515151;
    color: #ffffff;
}

.button--red:hover {
    background: #db5d5d;
    color: #ffffff;
}

.button--orange:hover {
    background: #ff9a55;
    color: #ffffff;
}

.button--blue:hover {
    background: #5d8bff;
    color: #ffffff;
}
</style>