---
interface Props {
    src: string;
    alt: string;
}

const { src, alt } = Astro.props;
---

<div class="image-container">
    <img class="image-box" src={src} alt={alt} />
</div>

<style>
    * {
        box-sizing: border-box;
    }

    /* Container-Konfiguration */
    .image-container {
        width: 100%;
        max-width: 100%;
    }

    /* Bildelemente und Transformationen */
    .image-box {
        display: block;
        width: 100%;
        max-width: 100%;
        height: auto;
        border: 3px solid var(--border-color);
        filter: drop-shadow(0.2em 0.2em 0 var(--shadow-color));
        transition: transform 0.08s ease, filter 0.08s ease;
    }

    /* Interaktions-Zustände */
    .image-box:hover {
        transform: translate(-0.1em, -0.1em);
        filter: drop-shadow(0.3em 0.3em 0 var(--shadow-color));
    }
</style>