---
interface Props {
    src: string;
    alt: string;
}

const { src, alt } = Astro.props;
---

<div class="image-container">
    <img class="image-box" src={src} alt={alt} />
</div>

<style>
    * {
        box-sizing: border-box;
    }

    .image-container {
        width: 100%;
        max-width: 100%;
        aspect-ratio: 4 / 5; /* Stabilisiert die Bildproportionen unabhängig von der Auflösung */
    }

    .image-box {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        border: 3px solid var(--border-color);
        filter: drop-shadow(0.2em 0.2em 0 var(--shadow-color));
        transition: transform 0.08s ease, filter 0.08s ease;
    }

    .image-box:hover {
        transform: translate(-0.1em, -0.1em);
        filter: drop-shadow(0.3em 0.3em 0 var(--shadow-color));
    }
</style>